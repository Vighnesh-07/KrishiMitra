# --- KrishiMitra .gitignore ---

# Environment & Secrets
# NEVER commit your secret keys. This is the most important rule.
.env

# Python Virtual Environment
# This folder contains installed libraries and is specific to your machine.
venv/
/venv/
.venv/
/.venv/

# Python Cache & Compiled Files
# These are auto-generated by Python and don't need to be in version control.
__pycache__/
*.pyc
*.pyo
*.pyd

# IDE / Editor Configuration
# Ignores settings files from popular code editors.
.vscode/
.idea/

# Operating System Files
# Ignores system-specific files from macOS and Windows.
.DS_Store
Thumbs.db

# Log files
*.log